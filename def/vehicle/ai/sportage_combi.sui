traffic_vehicle : traffic.sport_combi
{
	accessories[]: .sport_combi.chassis
	accessories[]: .sport_combi.fwheel
	accessories[]: .sport_combi.rwheel

	max_speed: 160

#@include "/def/vehicle/ai/colors/trace_helper_colors.sui"
#@include "/def/vehicle/ai/colors/most_popular_colors.sui"
@include "/def/vehicle/ai/colors/subaru_outback_colors.sui"

	vehicle_mass: 1700
	tags[]: expensive
	tags[]: common


@include "drivers_generic.sui"

}

vehicle_accessory: .sport_combi.chassis
{
	data_path: "/def/vehicle/ai/sportage_combi/chassis.sii"
}

vehicle_wheel_accessory: .sport_combi.fwheel
{
	offset: 0
	data_path: "/def/vehicle/ai_wheel/front_18in_o_1.sii"
}

vehicle_wheel_accessory: .sport_combi.rwheel
{
	offset: 0
	data_path: "/def/vehicle/ai_wheel/rear_18in_o_1.sii"
}