traffic_vehicle : traffic.featan.pickup
{
	accessories[]: .featan.pickup.chassis
	accessories[]: .featan.pickup.fwheel
	accessories[]: .featan.pickup.rwheel

	max_speed: 160

	sound_move[]: "/sound/traffic/car_v8_2.soundref"
	sound_horn[]: "/sound/traffic/car_horn_3.soundref"
	
	tags[]: pickup
	tags[]: empty
	tags[]: suv



	vehicle_mass: 3000

#@include "/def/vehicle/ai/colors/trace_helper_colors.sui"
#@include "/def/vehicle/ai/colors/most_popular_colors.sui"
@include "/def/vehicle/ai/colors/ford_f250_colors.sui"


@include "drivers_generic.sui"
	
}

vehicle_accessory: .featan.pickup.chassis
{
	data_path: "/def/vehicle/ai/featan_modular_truck_25/chassis.sii"
}

vehicle_wheel_accessory: .featan.pickup.fwheel
{
	offset: 0
		data_path: "/def/vehicle/ai_wheel/front_offroad.sii"
}

vehicle_wheel_accessory: .featan.pickup.rwheel
{
	offset: 0
	data_path: "/def/vehicle/ai_wheel/rear_offroad.sii"
}


