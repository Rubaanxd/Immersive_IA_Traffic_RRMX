traffic_vehicle : traffic.hd_pickup
{
	accessories[]: .hd_pickup.chassis
	accessories[]: .hd_pickup.fwheel
	accessories[]: .hd_pickup.rwheel

	max_speed: 160

	sound_move[]: "/sound/traffic/car_v8_2.soundref"
	sound_horn[]: "/sound/traffic/car_horn_3.soundref"
	
	tags[]: pickup
	tags[]: empty
	tags[]: suv

	vehicle_mass: 3000

#@include "/def/vehicle/ai/colors/trace_helper_colors.sui"
#@include "/def/vehicle/ai/colors/most_popular_colors.sui"
@include "/def/vehicle/ai/colors/chevrolet_silverado_colors.sui"


	
@include "drivers_generic.sui"
	
}

vehicle_accessory: .hd_pickup.chassis
{
	data_path: "/def/vehicle/ai/hd_pickup/chassis.sii"
}

vehicle_wheel_accessory: .hd_pickup.fwheel
{
	offset: 0
		data_path: "/def/vehicle/ai_wheel/front_box.sii"
}

vehicle_wheel_accessory: .hd_pickup.rwheel
{
	offset: 0
	data_path: "/def/vehicle/ai_wheel/rear_box.sii"
}




